# CHRONOS Environment Configuration
# Copy this file to .env and fill in your actual values

# ============ Threat Intelligence APIs ============
VT_API_KEY=your_virustotal_api_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
MISP_URL=https://your-misp-instance.com
MISP_API_KEY=your_misp_api_key_here
MISP_VERIFY_SSL=false
MISP_ENABLED=true

# ============ EDR Integration ============
WAZUH_API_URL=https://your-wazuh-server:55000
WAZUH_USERNAME=admin
WAZUH_PASSWORD=your_wazuh_password_here

# ============ Notifications ============
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
TEAMS_WEBHOOK_URL=https://outlook.webhook.office.com/webhookb2/...
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_FROM=your-email@gmail.com
EMAIL_PASSWORD=your_app_password_here

# ============ Grafana ============
GRAFANA_API_KEY=your_grafana_api_key_here
GRAFANA_URL=http://localhost:3000

# ============ Database ============
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=19200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=your_es_password_here
NEO4J_PASSWORD=your_neo4j_password_here

# ============ LLM Configuration ============
LLM_PROVIDER=ollama
LLM_API_URL=http://localhost:11434
LLM_MODEL=kimi-k2.5:cloud
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=60
LLM_MAX_RETRIES=3
LLM_CACHE_ENABLED=true
LLM_CACHE_TTL=3600
LLM_RATE_LIMIT_REQUESTS=60
LLM_RATE_LIMIT_PERIOD=60

# ============ Feature Flags ============
ENABLE_TBA=true
ENABLE_GRAPH_DETECTION=true
ENABLE_IDENTITY_THREATS=true
ENABLE_HUNTING=true
ENABLE_SOAR=true
ENABLE_SIGMA_RULES=true
ENABLE_ENDPOINT_AGENT=false

# ============ General Settings ============
CHRONOS_API_KEY=your-chronos-api-key-change-in-production
ENVIRONMENT=lab
LOG_LEVEL=INFO
DEBUG=false
